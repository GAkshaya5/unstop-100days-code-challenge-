#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// User logic function to process the basketball game scores
int user_logic(char** ops, int n) {
    int* stack = (int*)malloc(n * sizeof(int));
    int top = -1;

    for (int i = 0; i < n; ++i) {
        if (strcmp(ops[i], "+") == 0) {
            int new_score = stack[top] + stack[top - 1];
            stack[++top] = new_score;
        } 
        else if (strcmp(ops[i], "D") == 0) {
            int new_score = stack[top] * 2;
            stack[++top] = new_score;
        } 
        else if (strcmp(ops[i], "C") == 0) {
            top--;
        } 
        else {
            int new_score = atoi(ops[i]);
            stack[++top] = new_score;
        }
    }

    int total_score = 0;
    for (int i = 0; i <= top; ++i) {
        total_score += stack[i];
    }

    free(stack);
    return total_score;
}

// Driver main function required to handle platform execution
int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    // Allocate an array of strings to store the input operations
    char** ops = (char**)malloc(n * sizeof(char*));
    for (int i = 0; i < n; i++) {
        ops[i] = (char*)malloc(20 * sizeof(char)); // Expecting numbers or operations up to 20 chars
        if (scanf("%s", ops[i]) != 1) return 0;
    }

    // Call your logic and print the result
    int result = user_logic(ops, n);
    printf("%d\n", result);

    // Free allocated memory
    for (int i = 0; i < n; i++) {
        free(ops[i]);
    }
    free(ops);

    return 0;
}
