#include <stdio.h>

// User logic function
int highestAltitude(int n, int arr[]) {
    int current_altitude = 0;
    int max_altitude = 0; // Starts at 0 because the journey begins at 0m above sea level

    for (int i = 0; i < n; i++) {
        current_altitude += arr[i]; // Update current altitude with the net gain/loss
        if (current_altitude > max_altitude) {
            max_altitude = current_altitude; // Update the peak altitude reached so far
        }
    }

    return max_altitude;
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;
    
    int arr[n];
    for (int i = 0; i < n; ++i) {
        if (scanf("%d", &arr[i]) != 1) return 0;
    }
    
    // Call user logic function and print the output
    int result = highestAltitude(n, arr);
    printf("%d\n", result);
    
    return 0;
}
