#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define MAX 200005

long long int compareBits(char* a, char* b) {
    int n = strlen(a);
    int m = strlen(b);
    
    // Dynamically allocate prefix sum array for '1's in string b
    int* pref = (int*)malloc((m + 1) * sizeof(int));
    pref[0] = 0;
    
    for (int i = 0; i < m; i++) {
        pref[i + 1] = pref[i] + (b[i] == '1' ? 1 : 0);
    }
    
    long long int total_diff = 0;
    
    for (int i = 0; i < n; i++) {
        int start = i;
        int end = m - n + i;
        
        // Count total '1's in the range b[start ... end]
        int count_ones = pref[end + 1] - pref[start];
        int total_elements = end - start + 1;
        int count_zeros = total_elements - count_ones;
        
        if (a[i] == '0') {
            total_diff += count_ones;
        } else {
            total_diff += count_zeros;
        }
    }
    
    free(pref);
    return total_diff;
}

int main() {
    // Allocate memory for strings based on constraints (up to 2 * 10^5)
    char* a = (char*)malloc(MAX * sizeof(char));
    char* b = (char*)malloc(MAX * sizeof(char));
    
    // Read strings a and b from standard input
    if (scanf("%s", a) != 1) return 0;
    if (scanf("%s", b) != 1) return 0;
    
    // Calculate and print the result
    long long int result = compareBits(a, b);
    printf("%lld\n", result);
    
    // Clean up memory
    free(a);
    free(b);
    
    return 0;
}
